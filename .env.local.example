APP_NAME="ShopCI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# BASE DE DONNÉES MYSQL — Modifiez ces valeurs selon votre config
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=root
DB_PASSWORD=

# Si vous utilisez WAMP/XAMPP sous Windows :
# DB_USERNAME=root
# DB_PASSWORD=           (vide par défaut)

# Si vous utilisez MAMP sous macOS :
# DB_HOST=127.0.0.1
# DB_PORT=8889
# DB_USERNAME=root
# DB_PASSWORD=root

# Si vous avez créé un utilisateur dédié :
# DB_USERNAME=ecommerce
# DB_PASSWORD=ecommerce_pass_2024

# ============================================================
# CLÉ SECRÈTE ADMIN — Inscription d'un compte administrateur
# ============================================================
# Cette clé est requise pour créer un compte admin depuis la page
# d'inscription publique (/inscription). Changez-la impérativement
# en production. Ne la divulguez qu'aux personnes autorisées.
ADMIN_REGISTRATION_KEY="ShopCI@Admin2024!"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@shopci.com"
MAIL_FROM_NAME="${APP_NAME}"
